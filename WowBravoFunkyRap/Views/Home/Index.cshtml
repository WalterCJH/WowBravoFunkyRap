}

<div class="container-banner">
    <div class="banner">
        <section id="banner-slider" class="splide" aria-label="Splide Basic HTML Example">
            <div class="splide__arrows">
                <button class="splide__arrow splide__arrow--prev">
                    <i class="fa-solid fa-angle-left"></i>
                </button>
                <button class="splide__arrow splide__arrow--next">
                    <i class="fa-solid fa-angle-right"></i>
                </button>
            </div>
            <div class="splide__track">
                <ul class="splide__list">
                    @foreach (var item in Model.BannerImages)
                    {
                        <li class="splide__slide">
                            @if (string.IsNullOrWhiteSpace(item.ImageLink))
                            {
                                <picture>
                                    <source srcset="@item.ImageUrlSm" type="image/webp" media="(max-width:576px)">
                                    <source srcset="@item.ImageUrlXs" type="image/webp" media="(max-width:414px)">
                                    <img src="@item.ImageUrl" alt="@item.ImageAlt" title="@item.ImageTitle" class="mw-100">
                                </picture>
                            }
                            else
                            {
                                <a href="@item.ImageLink">
                                    <picture>
                                        <source srcset="@item.ImageUrlSm" type="image/webp" media="(max-width:576px)">
                                        <source srcset="@item.ImageUrlXs" type="image/webp" media="(max-width:414px)">
                                        <img src="@item.ImageUrl" alt="@item.ImageAlt" title="@item.ImageTitle" class="mw-100">
                                    </picture>
                                </a>
                            }
                        </li>
                    }
                </ul>
            </div>
            <div class="splide__progress">
                <div class="splide__progress__bar"></div>
                @*<div class="splide__progress__bar__item"></div>*@
            </div>
        </section>
    </div>
</div>

<div class="container">
    <div class="content">
        <div class="introduce">
            <div>
                <picture>
                    @*       <source srcset="~/Image/logo_horizontal.webp" type="image/webp" media="(min-width:577px)">
                    <source srcset="~/Image/logo_horizontal_m.webp" type="image/webp" media="(max-width:576px)">*@
                    <img src="~/Image/logo_horizontal.svg" alt="Logo Horizontal" title="Logo Horizontal" class="mw-100 logo-horizontal">
                </picture>
            </div>
            @*<img src="~/Image/logo_horizontal.svg" alt="" class="mw-100 logo-horizontal" />*@
            <div class="section-first">
                <p>
                    WOW BRAVO & FUNKY RAP 是一個堅持理想的台灣品牌，以精緻手工製作每一個設計細節，概念店 1F 以純白花園為意象，展示設計師們美麗的衣裳。
                </p>
                <p>
                    2F 為藝術空間，舉辦各類型創作展覽與表演活動，同時展示其他台灣年輕設計師品牌服裝。
                </p>
                <p>
                    3F 為設計師工作室，可接受客戶訂製。
                </p>
            </div>
            <p class="section-second">
                WOW BRAVO & FUNKY RAP is an ideal brand of fashion, insisted
                perfect handmade for every detail. The first floor of concept
                store is a white garden, showing those beautiful works of
                designers. Second floor is an art space, organizing various types
                of exhibitions and performing, and showing other young designers’
                works of Taiwan. Third floor for designers’ studio, customization
                is acceptable.
            </p>
        </div>
        <div class="brand-image">
            @*<img src="~/Image/brand-introduction.jpg" alt="" class="mw-100 exhibition" />*@
            <picture>
                <source srcset="~/Image/brand-introduction.webp" type="image/webp" media="(min-width:577px)">
                <source srcset="~/Image/brand-introduction_m.webp" type="image/webp" media="(max-width:576px)">
                <img src="~/Image/brand-introduction.jpg" alt="花的異想世界" title="花的異想世界" class="mw-100" loading="lazy">
            </picture>
        </div>
    </div>

    <div class="content-section">
        <div class="title">
            <div class="name-tw">最新資訊｜</div><div class="name-en">WHAT IS ON</div>
        </div>
        <section id="news-slider" class="splide" aria-label="Splide Basic HTML Example">
            <div class="splide__track">
                <ul class="splide__list">
                    @foreach (var item in Model.NewsImages)
                    {
                        <li class="splide__slide">
                            @if (string.IsNullOrWhiteSpace(item.ImageLink))
                            {
                                <picture>
                                    <source srcset="@item.ImageUrlSm" type="image/webp" media="(max-width:576px)">
                                    <source srcset="@item.ImageUrlXs" type="image/webp" media="(max-width:414px)">
                                    <img src="@item.ImageUrl" alt="@item.ImageAlt" title="@item.ImageTitle" class="mw-100">
                                </picture>
                            }
                            else
                            {
                                <a href="@item.ImageLink">
                                    <picture>
                                        <source srcset="@item.ImageUrlSm" type="image/webp" media="(max-width:576px)">
                                        <source srcset="@item.ImageUrlXs" type="image/webp" media="(max-width:414px)">
                                        <img src="@item.ImageUrl" alt="@item.ImageAlt" title="@item.ImageTitle" class="mw-100">
                                    </picture>
                                </a>
                            }
                        </li>
                    }
                </ul>
            </div>
            <div class="splide__progress">
                <div class="splide__progress__bar"></div>
            </div>
        </section>
    </div>

    <div class="content-section">
        <div class="inner-content-section">
            <div class="transportation-info">
                <div class="title">
                    <div class="name-tw">交通資訊｜</div><div class="name-en">TRANSPORTATION INFO</div>
                </div>
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3612.3965107573276!2d121.52986061484368!3d25.122282183931066!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442ae7e9a9974e1%3A0x3ae46b51dbe03b57!2sWOW%20BRAVO%20%26%20FUNKY%20RAP!5e0!3m2!1szh-TW!2stw!4v1677314012798!5m2!1szh-TW!2stw" width="400" height="150" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="WOW BRAVO & FUNKY RAP Google Map"></iframe>
            </div>
            <div class="address-info d-none d-lg-block">
                <div class="address-left">W&F ADDRESS：</div>
                <div class="address-right">
                    <div class="address-item name-tw">台北市士林區中山北路七段118號</div>
                    <div class="address-item name-en">No.118, Sec.7, Zhongshan N. Rd., Shilin Dist., Taipei City 11151</div>
                    <div class="address-item">營業時間 TIME / 13:30-21:30</div>
                    <div class="address-item">(02) 2874-0517</div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-section">
        @*<img src="~/Image/W&F-MAP.jpg" alt="" class="mw-100 logo-horizontal" />*@
        <picture>
            <source srcset="~/Image/W&F-MAP.webp" type="image/webp" media="(min-width:577px)">
            <source srcset="~/Image/W&F-MAP_m.webp" type="image/webp" media="(max-width:576px)">
            <img src="~/Image/W&F-MAP.jpg" alt="W&F地圖" title="W&F地圖" class="mw-100" loading="lazy">
        </picture>
    </div>
</div>
