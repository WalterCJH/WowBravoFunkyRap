@{
    string title = ViewData["Title"]?.ToString();
    if (!string.IsNullOrWhiteSpace(title))
    {
        title = $"{title} • ";
    }

    title += "WOW BRAVO & FUNKY RAP";
}

<!DOCTYPE html>
