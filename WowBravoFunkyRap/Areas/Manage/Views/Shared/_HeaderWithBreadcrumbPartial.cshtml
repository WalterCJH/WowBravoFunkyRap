@model HeaderWithBreadcrumb

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>@ViewData["Title"]</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                    @if (Model != null)
                    {
                        foreach (var item in Model.BreadcrumbItems)
                        {
                            <li class="breadcrumb-item">
                                <a asp-action="@item.Action" asp-controller="@item.Controller" asp-area="@item.Area" asp-route-id="@item.Id">@item.Title</a>
                            </li>
                        }
                    }
                    <li class="breadcrumb-item active"><span>@ViewData["Title"]</span></li>
                </ol>
            </div>
        </div>
    </div>
</section>
